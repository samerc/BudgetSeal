  "privacyWebCompanionTitle": "3. Compagnon Web",
  "@privacyWebCompanionTitle": { "description": "Heading" },
  "privacyWebCompanionBody": "La fonctionnalité Compagnon Web exécute un serveur HTTP local sur votre téléphone. Il n'est accessible que depuis les appareils sur le même réseau WiFi. Aucune donnée n'est envoyée sur Internet. La connexion est protégée par un code PIN, des jetons de session et une limitation de débit. Le serveur s'arrête automatiquement après 6 heures.",
  "@privacyWebCompanionBody": { "description": "Body" },
  "privacyAnalyticsTitle": "4. Analyses et suivi",
  "@privacyAnalyticsTitle": { "description": "Heading" },
  "privacyAnalyticsBody": "BudgetSeal n'inclut aucun SDK d'analyse, outil de rapport de plantage, bibliothèque publicitaire ou pixel de suivi. Aucune donnée d'utilisation, identifiant d'appareil ou métrique comportementale n'est collectée.",
  "@privacyAnalyticsBody": { "description": "Body" },
  "privacyPermissionsTitle": "5. Autorisations",
  "@privacyPermissionsTitle": { "description": "Heading" },
  "privacyPermissionsBody": "\u2022 Caméra \u2014 utilisée uniquement pour le scan de reçus\n\u2022 Notifications \u2014 rappels quotidiens et alertes de factures\n\u2022 Biométrie \u2014 verrouillage optionnel de l'application\n\u2022 Réseau \u2014 uniquement pour la synchronisation cloud et les taux de change\n\u2022 Réseau local \u2014 serveur Compagnon Web\n\nToutes les autorisations sont optionnelles et peuvent être refusées sans affecter les fonctionnalités principales.",
  "@privacyPermissionsBody": { "description": "Body" },
  "privacyReceiptsTitle": "6. Images de reçus",
  "@privacyReceiptsTitle": { "description": "Heading" },
  "privacyReceiptsBody": "Les photos de reçus sont stockées dans le répertoire privé de l'application sur votre appareil. Elles ne sont téléchargées nulle part sauf si vous activez la synchronisation des reçus via Google Drive. Le traitement OCR est effectué entièrement hors ligne.",
  "@privacyReceiptsBody": { "description": "Body" },
  "privacyBackupsTitle": "7. Sauvegardes",
  "@privacyBackupsTitle": { "description": "Heading" },
  "privacyBackupsBody": "Les sauvegardes automatiques sont stockées localement dans le répertoire documents de l'application. Vous contrôlez la fréquence et la rétention des sauvegardes.",
  "@privacyBackupsBody": { "description": "Body" },
  "termsOfUseTitle": "Conditions d'utilisation",
  "@termsOfUseTitle": { "description": "Section title" },
  "termsAcceptanceTitle": "1. Acceptation",
  "@termsAcceptanceTitle": { "description": "Heading" },
  "termsAcceptanceBody": "En utilisant BudgetSeal, vous acceptez ces conditions. Si vous n'êtes pas d'accord, veuillez désinstaller l'application.",
  "@termsAcceptanceBody": { "description": "Body" },
  "termsIntendedUseTitle": "2. Utilisation prévue",
  "@termsIntendedUseTitle": { "description": "Heading" },
  "termsIntendedUseBody": "BudgetSeal est un outil de gestion financière personnelle pour la budgétisation individuelle et familiale. Il n'est pas destiné à la comptabilité commerciale, la préparation fiscale ou les conseils financiers.",
  "@termsIntendedUseBody": { "description": "Body" },
  "termsDataAccuracyTitle": "3. Exactitude des données",
  "@termsDataAccuracyTitle": { "description": "Heading" },
  "termsDataAccuracyBody": "Vous êtes responsable de l'exactitude des données que vous saisissez. BudgetSeal calcule les soldes, budgets et rapports en fonction de vos saisies. Les taux de change provenant de sources externes sont approximatifs.",
  "@termsDataAccuracyBody": { "description": "Body" },
  "termsNoWarrantyTitle": "4. Sans garantie",
  "@termsNoWarrantyTitle": { "description": "Heading" },
  "termsNoWarrantyBody": "BudgetSeal est fourni \"tel quel\" sans garantie d'aucune sorte. Bien que nous nous efforcions d'assurer la fiabilité, nous ne pouvons pas garantir que l'application sera exempte d'erreurs. Des sauvegardes régulières sont fortement recommandées.",
  "@termsNoWarrantyBody": { "description": "Body" },
  "termsLiabilityTitle": "5. Limitation de responsabilité",
  "@termsLiabilityTitle": { "description": "Heading" },
  "termsLiabilityBody": "Le développeur ne sera pas responsable des dommages directs, indirects, accessoires ou consécutifs résultant de l'utilisation de BudgetSeal.",
  "@termsLiabilityBody": { "description": "Body" },
  "termsIPTitle": "6. Propriété intellectuelle",
  "@termsIPTitle": { "description": "Heading" },
  "termsIPBody": "BudgetSeal et son contenu original sont protégés par le droit d'auteur. L'application utilise des bibliothèques open source listées dans la section Licences.",
  "@termsIPBody": { "description": "Body" },
  "termsChangesTitle": "7. Modifications",
  "@termsChangesTitle": { "description": "Heading" },
  "termsChangesBody": "Ces conditions peuvent être mises à jour avec les nouvelles versions de l'application. L'utilisation continue après une mise à jour constitue l'acceptation des conditions révisées.",
  "@termsChangesBody": { "description": "Body" },
  "termsContactTitle": "8. Contact",
  "@termsContactTitle": { "description": "Heading" },
  "termsContactBody": "Pour toute question ou préoccupation concernant cette politique de confidentialité ou ces conditions d'utilisation, contactez : samer@budgetseal.app",
  "@termsContactBody": { "description": "Body" },
