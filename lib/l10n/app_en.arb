  "privacyTermsTitle": "Privacy & Terms",
  "@privacyTermsTitle": { "description": "AppBar title" },
  "privacyPolicyTitle": "Privacy Policy",
  "@privacyPolicyTitle": { "description": "Section title" },
  "privacyLastUpdated": "Last updated: May 2026",
  "@privacyLastUpdated": { "description": "Date" },
  "privacyIntro": "PocketPlan is designed with your privacy as a core principle. Your financial data belongs to you \u2014 we never collect, store, or transmit it to any server.",
  "@privacyIntro": { "description": "Introduction" },
  "privacyDataStorageTitle": "1. Data Storage",
  "@privacyDataStorageTitle": { "description": "Heading" },
  "privacyDataStorageBody": "All your financial data (transactions, accounts, envelopes, categories, goals, and settings) is stored locally on your device in an SQLite database. No data leaves your device unless you explicitly enable Cloud Sync.",
  "@privacyDataStorageBody": { "description": "Body" },
  "privacyCloudSyncTitle": "2. Cloud Sync (Optional)",
  "@privacyCloudSyncTitle": { "description": "Heading" },
  "privacyCloudSyncBody": "If you choose to enable Cloud Sync, your data is uploaded to your personal Google Drive account or a file storage provider you select. PocketPlan does not have access to your Google account credentials \u2014 authentication is handled by Google's OAuth system.\n\nYou may optionally encrypt your sync file with AES-256 encryption using a password you set. The password is stored only on your device in secure storage (Android Keystore / iOS Keychain).",
  "@privacyCloudSyncBody": { "description": "Body" },
  "privacyWebCompanionTitle": "3. Web Companion",
  "@privacyWebCompanionTitle": { "description": "Heading" },
  "privacyWebCompanionBody": "The Web Companion feature runs a local HTTP server on your phone. It is only accessible from devices on the same WiFi network (private IP addresses). No data is sent to the internet. The connection is protected by a PIN, session tokens, and rate limiting. The server stops automatically after 6 hours.",
  "@privacyWebCompanionBody": { "description": "Body" },
  "privacyAnalyticsTitle": "4. Analytics & Tracking",
  "@privacyAnalyticsTitle": { "description": "Heading" },
  "privacyAnalyticsBody": "PocketPlan does not include any analytics SDKs, crash reporting tools, advertising libraries, or tracking pixels. No usage data, device identifiers, or behavioral metrics are collected.",
  "@privacyAnalyticsBody": { "description": "Body" },
  "privacyPermissionsTitle": "5. Permissions",
  "@privacyPermissionsTitle": { "description": "Heading" },
  "privacyPermissionsBody": "\u2022 Camera \u2014 used only for receipt scanning (offline OCR)\n\u2022 Notifications \u2014 daily reminders and bill alerts\n\u2022 Biometrics \u2014 optional app lock\n\u2022 Network \u2014 only for Cloud Sync and exchange rate fetching\n\u2022 Local Network \u2014 Web Companion server\n\nAll permissions are optional and can be denied without affecting core functionality.",
  "@privacyPermissionsBody": { "description": "Body" },
  "privacyReceiptsTitle": "6. Receipt Images",
  "@privacyReceiptsTitle": { "description": "Heading" },
  "privacyReceiptsBody": "Receipt photos are stored in the app's private directory on your device. They are not uploaded anywhere unless you enable receipt sync via Google Drive. OCR processing is performed entirely offline using on-device ML.",
  "@privacyReceiptsBody": { "description": "Body" },
  "privacyBackupsTitle": "7. Backups",
  "@privacyBackupsTitle": { "description": "Heading" },
  "privacyBackupsBody": "Automatic backups are stored locally in the app's documents directory. You control backup frequency and retention. Exported backup files are shared via the system share sheet and deleted from temporary storage afterward.",
  "@privacyBackupsBody": { "description": "Body" },
  "termsOfUseTitle": "Terms of Use",
  "@termsOfUseTitle": { "description": "Section title" },
  "termsAcceptanceTitle": "1. Acceptance",
  "@termsAcceptanceTitle": { "description": "Heading" },
  "termsAcceptanceBody": "By using PocketPlan, you agree to these terms. If you do not agree, please uninstall the app.",
  "@termsAcceptanceBody": { "description": "Body" },
  "termsIntendedUseTitle": "2. Intended Use",
  "@termsIntendedUseTitle": { "description": "Heading" },
  "termsIntendedUseBody": "PocketPlan is a personal finance management tool for individual and household budgeting. It is not intended for commercial accounting, tax preparation, or financial advice. The app provides tools to organize your finances \u2014 it does not provide financial recommendations.",
  "@termsIntendedUseBody": { "description": "Body" },
  "termsDataAccuracyTitle": "3. Data Accuracy",
  "@termsDataAccuracyTitle": { "description": "Heading" },
  "termsDataAccuracyBody": "You are responsible for the accuracy of the data you enter. PocketPlan calculates balances, budgets, and reports based on your input. Exchange rates fetched from external sources are approximate and may not reflect real-time market rates.",
  "@termsDataAccuracyBody": { "description": "Body" },
  "termsNoWarrantyTitle": "4. No Warranty",
  "@termsNoWarrantyTitle": { "description": "Heading" },
  "termsNoWarrantyBody": "PocketPlan is provided \"as is\" without warranty of any kind. While we strive for reliability, we cannot guarantee that the app will be error-free or uninterrupted. Regular backups are strongly recommended.",
  "@termsNoWarrantyBody": { "description": "Body" },
  "termsLiabilityTitle": "5. Limitation of Liability",
  "@termsLiabilityTitle": { "description": "Heading" },
  "termsLiabilityBody": "The developer shall not be liable for any direct, indirect, incidental, or consequential damages arising from the use of PocketPlan, including but not limited to data loss, financial miscalculations, or sync failures.",
  "@termsLiabilityBody": { "description": "Body" },
  "termsIPTitle": "6. Intellectual Property",
  "@termsIPTitle": { "description": "Heading" },
  "termsIPBody": "PocketPlan and its original content are protected by copyright. The app uses open-source libraries listed in the Licenses section of the About screen.",
  "@termsIPBody": { "description": "Body" },
  "termsChangesTitle": "7. Changes",
  "@termsChangesTitle": { "description": "Heading" },
  "termsChangesBody": "These terms may be updated with new app versions. Continued use after an update constitutes acceptance of the revised terms.",
  "@termsChangesBody": { "description": "Body" },
  "termsContactTitle": "8. Contact",
  "@termsContactTitle": { "description": "Heading" },
  "termsContactBody": "For questions or concerns about this privacy policy or terms of use, contact: samer@pocketplan.app",
  "@termsContactBody": { "description": "Body" },
